{
  "ignorePatterns": [
    {
      "pattern": "^[^h].*"
    },
    {
      "pattern": "^mailto:"
    },
    {
      "pattern": "^#"
    },
    {
      "pattern": "^\\./.*"
    },
    {
      "pattern": "^\\.\\.\\/.*"
    },
    {
      "pattern": "docs/.*\\.md"
    },
    {
      "pattern": ".*_%.*"
    },
    {
      "pattern": "^https://example\\.com"
    },
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "conventional-changelog.*tree/master/packages/conventional-changelog-cli"
    }
  ],
  "timeout": "10s",
  "retryOn429": true,
  "retryCount": 3,
  "fallbackRetryDelay": "30s",
  "aliveStatusCodes": [200, 206, 301, 302]
}